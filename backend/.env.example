# PenguWave backend configuration — copy to `.env` and fill in real values.
# NEVER commit the real .env file.

# Server
PORT=3001
NODE_ENV=development

# Frontend origin allowed by CORS
FRONTEND_URL=http://localhost:5173

# Auth secrets — generate strong random values, min 32 chars each.
# e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_ACCESS_SECRET=replace-with-32+-char-random-secret
JWT_REFRESH_SECRET=replace-with-different-32+-char-random-secret

# Access token lifetime (refresh handles longer sessions)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Optional — AI incident assistant via AWS Bedrock (feature-gated).
# If these are unset the server still boots; POST /api/events/:id/analyze
# returns 502 until all three AWS_* values are provided.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# On-demand Claude model id (or a cross-region inference profile id for your account)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
